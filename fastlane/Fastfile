require "shellwords"
require "fileutils"
require "tempfile"

default_platform(:ios)

# ---------------------------------------------------------------------------
# Shared helper: verify all required env vars are present and that the bundle
# ID stored in APP_IDENTIFIER matches the expected value.
# ---------------------------------------------------------------------------
EXPECTED_APP_IDENTIFIER = "com.savagesbydesign.CathedralOS".freeze

def preflight_checks(required_vars)
  missing = required_vars.select { |v| ENV[v].to_s.strip.empty? }
  unless missing.empty?
    UI.user_error!("Missing required secret(s): #{missing.join(', ')}. " \
                   "Add them under Settings → Secrets and variables → Actions.")
  end

  app_id = ENV["APP_IDENTIFIER"].to_s.strip
  unless app_id.empty? || app_id == EXPECTED_APP_IDENTIFIER
    UI.user_error!("APP_IDENTIFIER is '#{app_id}' but must be " \
                   "'#{EXPECTED_APP_IDENTIFIER}'. " \
                   "Update the secret to match the Xcode project bundle ID.")
  end
end

platform :ios do
  # ---------------------------------------------------------------------------
  # beta — build a signed archive and upload to TestFlight
  # ---------------------------------------------------------------------------
  # Required environment variables (set as GitHub Secrets):
  #   ASC_KEY_ID        — App Store Connect API key ID
  #   ASC_ISSUER_ID     — App Store Connect issuer ID
  #   ASC_API_KEY       — Base64-encoded .p8 private key contents
  #   APPLE_TEAM_ID     — 10-character Apple Developer Team ID
  #   APP_IDENTIFIER    — Bundle ID: com.savagesbydesign.CathedralOS
  #   MATCH_GIT_URL     — HTTPS URL of the private Match certificates repo
  #   MATCH_PASSWORD    — Passphrase used to encrypt Match assets
  #   MATCH_GIT_TOKEN   — Personal access token for the Match repo (read access)
  #   MATCH_READONLY    — (optional) Set to "false" to allow Match to refresh
  #                       certs/profiles; defaults to "true" (readonly)
  #   SUPABASE_PROJECT_URL — Supabase project URL (public, injected into Info.plist)
  #   SUPABASE_ANON_KEY    — Supabase anon/public key (injected into Info.plist)
  # ---------------------------------------------------------------------------
  lane :beta do
    preflight_checks(%w[
      ASC_KEY_ID ASC_ISSUER_ID ASC_API_KEY
      APPLE_TEAM_ID APP_IDENTIFIER
      MATCH_GIT_URL MATCH_PASSWORD MATCH_GIT_TOKEN
      SUPABASE_PROJECT_URL SUPABASE_ANON_KEY
    ])

    ci_environment = is_ci

    # --- App Store Connect API key auth ---
    app_store_connect_api_key(
      key_id:                ENV["ASC_KEY_ID"],
      issuer_id:             ENV["ASC_ISSUER_ID"],
      key_content:           ENV["ASC_API_KEY"],
      is_key_content_base64: true,
      in_house:              false
    )

    # --- Create a dedicated CI keychain for code signing ---
    create_keychain(
      name:             "ci_keychain",
      password:         ENV["MATCH_PASSWORD"],
      default_keychain: true,
      unlock:           true,
      timeout:          3600,
      lock_when_sleeps: false
    )

    # --- Code signing via Match ---
    # readonly mode defaults to true; set MATCH_READONLY=false to refresh assets
    readonly_mode = (ENV["MATCH_READONLY"] || "true").downcase == "true"
    match(
      type:                    "appstore",
      readonly:                readonly_mode,
      keychain_name:           "ci_keychain",
      keychain_password:       ENV["MATCH_PASSWORD"],
      git_basic_authorization: Base64.strict_encode64("x-access-token:#{ENV['MATCH_GIT_TOKEN']}")
    )

    # --- Increment build number to the current timestamp (CI-safe) ---
    # Use agvtool directly (without -all) so it only updates CURRENT_PROJECT_VERSION
    # in the .xcodeproj and does not scan for Info.plist files.  With
    # GENERATE_INFOPLIST_FILE=YES there is no physical plist to update, and the
    # agvtool -all flag produces a spurious "Cannot find …/YES" warning.
    # Run from the project root (parent of the fastlane/ folder) where agvtool
    # can locate CathedralOSApp.xcodeproj.
    build_num = Time.now.utc.strftime("%Y%m%d%H%M%S")
    project_root = File.expand_path("..", __dir__)
    Dir.chdir(project_root) do
      sh("agvtool", "new-version", build_num)
    end

    # --- Build signed archive ---
    # SUPABASE_* build settings feed the target's INFOPLIST_KEY_* mappings for
    # the generated Info.plist (used when GENERATE_INFOPLIST_FILE=YES). Only the
    # public anon key and project URL are injected here — no service-role keys
    # or DB passwords.
    xcargs_parts = [
      "SUPABASE_PROJECT_URL=#{ENV['SUPABASE_PROJECT_URL'].to_s.shellescape}",
      "SUPABASE_ANON_KEY=#{ENV['SUPABASE_ANON_KEY'].to_s.shellescape}"
    ]
    xcargs = xcargs_parts.join(" ")

    UI.message("Skipping Active Release INFOPLIST_KEY_* diagnostic; built IPA Info.plist verification is the source of truth.")

    gym(
      project:          "CathedralOSApp.xcodeproj",
      scheme:           "CathedralOSApp",
      configuration:    "Release",
      sdk:              "iphoneos",
      export_method:    "app-store",
      export_options:   {
        provisioningProfiles: {
          ENV["APP_IDENTIFIER"] => "match AppStore #{ENV['APP_IDENTIFIER']}"
        }
      },
      output_directory: "./build",
      output_name:      "CathedralOSApp.ipa",
      clean:            true,
      xcargs:           xcargs,
      export_xcargs:    "-allowProvisioningUpdates"
    )

    # --- Verify built IPA contains runtime Supabase keys ---
    ipa_path = lane_context[SharedValues::IPA_OUTPUT_PATH].to_s
    UI.user_error!("IPA_OUTPUT_PATH was empty after gym") if ipa_path.empty?
    ipa_path = File.expand_path(ipa_path)

    verify_dir = File.join(File.dirname(ipa_path), "ipa_verify")
    expected_verify_prefix = File.dirname(ipa_path) + File::SEPARATOR
    unless verify_dir.start_with?(expected_verify_prefix)
      UI.user_error!("Refusing to clear unexpected verify directory path: #{verify_dir}")
    end

    UI.user_error!("Expected IPA not found at #{ipa_path}") unless File.exist?(ipa_path)

    FileUtils.rm_rf(verify_dir) if File.exist?(verify_dir)
    FileUtils.mkdir_p(verify_dir)
    sh("unzip", "-q", ipa_path, "-d", verify_dir)

    plist_path = File.join(verify_dir, "Payload", "CathedralOSApp.app", "Info.plist")
    UI.user_error!("Expected Info.plist not found in built IPA at #{plist_path}") unless File.exist?(plist_path)

    read_plist_value = lambda do |plist_key|
      begin
        sh(
          "/usr/bin/plutil",
          "-extract",
          plist_key,
          "raw",
          "-o",
          "-",
          plist_path,
          log: false
        ).to_s.strip
      rescue StandardError
        UI.message("Built IPA plist key lookup for #{plist_key} returned non-success status; treating as missing.")
        ""
      end
    end

    url_present = !read_plist_value.call("SupabaseProjectURL").empty?
    anon_present = !read_plist_value.call("SupabaseAnonKey").empty?

    UI.message("Built IPA SupabaseProjectURL present: #{url_present ? 'yes' : 'no'}")
    UI.message("Built IPA SupabaseAnonKey present: #{anon_present ? 'yes' : 'no'}")

    UI.user_error!("Built IPA is missing SupabaseProjectURL") unless url_present
    UI.user_error!("Built IPA is missing SupabaseAnonKey") unless anon_present

    # --- Upload to TestFlight ---
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  ensure
    # Cleanup: remove the CI keychain so it doesn't persist between runs.
    # Guard with rescue in case create_keychain was never reached.
    begin
      delete_keychain(name: "ci_keychain") if ci_environment
    rescue => e
      UI.important("⚠️  Could not delete CI keychain: #{e.message}")
    end
  end

  # ---------------------------------------------------------------------------
  # bootstrap_signing — one-time lane to create missing distribution certs and
  # provisioning profiles in the Match repo, entirely from CI.
  #
  # Run via GitHub Actions → Bootstrap Signing → Run workflow.
  # MATCH_GIT_TOKEN must have *write* access to the certs repo for this lane.
  # After a successful bootstrap, normal `beta` runs use readonly mode.
  # ---------------------------------------------------------------------------
  # Required environment variables (same as beta, but MATCH_GIT_TOKEN needs
  # write access to the Match certificates repository):
  #   ASC_KEY_ID  ASC_ISSUER_ID  ASC_API_KEY
  #   APPLE_TEAM_ID  APP_IDENTIFIER
  #   MATCH_GIT_URL  MATCH_PASSWORD  MATCH_GIT_TOKEN (write access)
  # ---------------------------------------------------------------------------
  lane :bootstrap_signing do
    preflight_checks(%w[
      ASC_KEY_ID ASC_ISSUER_ID ASC_API_KEY
      APPLE_TEAM_ID APP_IDENTIFIER
      MATCH_GIT_URL MATCH_PASSWORD MATCH_GIT_TOKEN
    ])

    ci_environment = is_ci

    # --- App Store Connect API key auth ---
    app_store_connect_api_key(
      key_id:                ENV["ASC_KEY_ID"],
      issuer_id:             ENV["ASC_ISSUER_ID"],
      key_content:           ENV["ASC_API_KEY"],
      is_key_content_base64: true,
      in_house:              false
    )

    # --- Create a dedicated CI keychain for code signing ---
    create_keychain(
      name:             "ci_keychain",
      password:         ENV["MATCH_PASSWORD"],
      default_keychain: true,
      unlock:           true,
      timeout:          3600,
      lock_when_sleeps: false
    )

    UI.message("🔑 Bootstrapping Match signing assets (readonly: false) …")
    UI.message("   App identifier : #{ENV['APP_IDENTIFIER']}")
    UI.message("   Match repo     : #{ENV['MATCH_GIT_URL']}")

    # --- Create (or refresh) distribution cert + provisioning profile ---
    # readonly: false allows Match to generate and push new assets to the repo.
    match(
      type:                    "appstore",
      readonly:                false,
      keychain_name:           "ci_keychain",
      keychain_password:       ENV["MATCH_PASSWORD"],
      git_basic_authorization: Base64.strict_encode64("x-access-token:#{ENV['MATCH_GIT_TOKEN']}")
    )

    UI.success("✅ Bootstrap complete. Run the TestFlight Deploy workflow next.")
  ensure
    # Cleanup: remove the CI keychain so it doesn't persist between runs.
    # Guard with rescue in case create_keychain was never reached.
    begin
      delete_keychain(name: "ci_keychain") if ci_environment
    rescue => e
      UI.important("⚠️  Could not delete CI keychain: #{e.message}")
    end
  end

  # ---------------------------------------------------------------------------
  # refresh_profiles — re-create the App Store provisioning profile from scratch
  # so that newly enabled capabilities (e.g. Sign in with Apple) are included.
  #
  # Run via GitHub Actions → Bootstrap Signing → Run workflow, or locally:
  #   bundle exec fastlane refresh_profiles
  #
  # Set MATCH_READONLY=false (or omit it) before running this lane.
  # MATCH_GIT_TOKEN must have *write* access to the Match certificates repo.
  #
  # After a successful refresh, the next beta build will pick up the updated
  # profile automatically (MATCH_READONLY can be set back to "true").
  # ---------------------------------------------------------------------------
  lane :refresh_profiles do
    preflight_checks(%w[
      ASC_KEY_ID ASC_ISSUER_ID ASC_API_KEY
      APPLE_TEAM_ID APP_IDENTIFIER
      MATCH_GIT_URL MATCH_PASSWORD MATCH_GIT_TOKEN
    ])

    ci_environment = is_ci

    app_store_connect_api_key(
      key_id:                ENV["ASC_KEY_ID"],
      issuer_id:             ENV["ASC_ISSUER_ID"],
      key_content:           ENV["ASC_API_KEY"],
      is_key_content_base64: true,
      in_house:              false
    )

    create_keychain(
      name:             "ci_keychain",
      password:         ENV["MATCH_PASSWORD"],
      default_keychain: true,
      unlock:           true,
      timeout:          3600,
      lock_when_sleeps: false
    )

    UI.message("🔄 Regenerating App Store provisioning profile (readonly: false) …")
    UI.message("   This ensures capabilities such as Sign in with Apple are included.")
    UI.message("   App identifier : #{ENV['APP_IDENTIFIER']}")
    UI.message("   Match repo     : #{ENV['MATCH_GIT_URL']}")

    # force: true re-generates the profile so newly enabled capabilities
    # (such as Sign in with Apple) are included.
    match(
      type:                    "appstore",
      readonly:                false,
      force:                   true,
      keychain_name:           "ci_keychain",
      keychain_password:       ENV["MATCH_PASSWORD"],
      git_basic_authorization: Base64.strict_encode64("x-access-token:#{ENV['MATCH_GIT_TOKEN']}")
    )

    UI.success("✅ Profile refresh complete. The next beta build will use the updated profile.")
  ensure
    begin
      delete_keychain(name: "ci_keychain") if ci_environment
    rescue => e
      UI.important("⚠️  Could not delete CI keychain: #{e.message}")
    end
  end

  # ---------------------------------------------------------------------------
  # verify_profile_entitlements — verify the installed App Store provisioning
  # profile includes the Sign in with Apple entitlement.
  #
  # This lane is intentionally separate from `beta` so profile/capability issues
  # fail fast as signing configuration blockers.
  # ---------------------------------------------------------------------------
  lane :verify_profile_entitlements do
    preflight_checks(%w[
      APP_IDENTIFIER
      MATCH_GIT_URL MATCH_PASSWORD MATCH_GIT_TOKEN
    ])

    match(
      type:                    "appstore",
      readonly:                true,
      git_basic_authorization: Base64.strict_encode64("x-access-token:#{ENV['MATCH_GIT_TOKEN']}")
    )

    app_identifier = ENV["APP_IDENTIFIER"].to_s.strip
    profiles_pattern = File.join(Dir.home, "Library", "Developer", "Xcode", "UserData", "Provisioning Profiles", "*.mobileprovision")
    profile_paths = Dir[profiles_pattern].sort_by { |path| File.mtime(path) }.reverse
    UI.user_error!("No installed provisioning profiles found at #{profiles_pattern}") if profile_paths.empty?

    matching_profile = nil
    has_sign_in_with_apple = false

    profile_paths.each do |profile_path|
      begin
        decoded_xml = begin
          sh("/usr/bin/security", "cms", "-D", "-i", profile_path, log: false).to_s
        rescue StandardError => e
          UI.verbose("Skipping profile #{profile_path}: unable to decode mobileprovision (#{e.message})")
          next
        end

        if decoded_xml.strip.empty? || !decoded_xml.include?("<plist")
          UI.verbose("Skipping profile #{profile_path}: decoded profile is empty or invalid plist.")
          next
        end

        Tempfile.create(["profile-entitlements-", ".plist"]) do |tmp|
          tmp.write(decoded_xml)
          tmp.flush
          candidate_app_identifier = begin
            sh(
              "/usr/libexec/PlistBuddy",
              "-c",
              "Print :Entitlements:application-identifier",
              tmp.path,
              log: false
            ).to_s.strip
          rescue StandardError
            UI.verbose("Skipping profile #{profile_path}: missing Entitlements:application-identifier.")
            next
          end

          # application-identifier format is expected to be "TeamID.BundleID".
          candidate_parts = candidate_app_identifier.split(".", 2)
          if candidate_parts.length < 2 || candidate_parts[1].to_s.strip.empty?
            UI.verbose("Skipping profile #{profile_path}: invalid application-identifier #{candidate_app_identifier.inspect}.")
            next
          end
          candidate_bundle_identifier = candidate_parts[1].to_s
          next unless candidate_bundle_identifier == app_identifier

          matching_profile = profile_path
          entitlement_value = begin
            sh(
              "/usr/libexec/PlistBuddy",
              "-c",
              "Print :Entitlements:com.apple.developer.applesignin:0",
              tmp.path,
              log: false
            ).to_s.strip
          rescue StandardError
            ""
          end
          has_sign_in_with_apple = !entitlement_value.empty?
        end

        break if matching_profile
      rescue StandardError => e
        UI.verbose("Skipping profile #{profile_path}: #{e.message}")
      end
    end

    if matching_profile.nil?
      UI.user_error!("No installed App Store provisioning profile matched #{app_identifier}. " \
                     "Run `fastlane refresh_profiles` first, then re-run `fastlane verify_profile_entitlements`.")
    end

    unless has_sign_in_with_apple
      UI.user_error!("BLOCKER: Identifier #{app_identifier} does not have Sign in with Apple enabled in the Apple Developer portal. " \
                     "Enable Sign in with Apple for this identifier and run `fastlane refresh_profiles` to regenerate the profile.")
    end

    UI.success("✅ Verified provisioning profile entitlement: com.apple.developer.applesignin present.")
  end
end
